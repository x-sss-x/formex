# Public API prefix (browser). Default uses Next rewrite → Laravel (see next.config.ts).
NEXT_PUBLIC_API_BASE_URL=/backend/api

# Origin of this Next app (server-side fetch when building absolute URLs).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Laravel base URL for server components and UploadThing (direct HTTP, not through Next).
LARAVEL_BACKEND_URL=http://127.0.0.1:8000
{
  "name": "formex",
  "type": "module",
  "private": true,
   "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "clean:workspaces": "turbo run clean",
    "clean":"rm -rf node_modules .turbo",
    "postinstall": "bun --filter=\"@formex/api\" composer:install",
    "api:openapi-export": "bun --filter=\"@formex/api\" openapi:export",
    "web:api-codegen": "bun --filter=\"@formex/web\" api:codegen",
    "sync:api": "bun run api:openapi-export && bun run web:api-codegen"
  },
  "packageManager": "bun@1.3.9",
  "peerDependencies": {
    "turbo": "^2.8.21",
    "typescript": "^5"
  },
  "workspaces":[
    "apps/*"
  ]
}

# Get database url with your integrated PHP Backend 
DATABASE_URL=mysql://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:3306/<DB_NAME>

# Better auth secret value used for encryption and hashing. It must be at least 32 characters and generated with high entropy.
# Click the button below to generate one. You can also use `openssl rand -base64 32` to generate one.
# Otherwise you directly go to this link https://better-auth.com/docs/installation#set-environment-variables
# and click on 'Generate Secret' button get the unique secret.
BETTER_AUTH_SECRET='<secret>'

# Uploadthing token https://uploadthing.com
UPLOADTHING_TOKEN='<token>'